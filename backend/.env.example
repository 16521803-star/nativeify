# =============================================================
#  Nativeify Backend — Environment Variables
#  Copy to .env and adjust for your local setup.
# =============================================================

# ── Backend Server ───────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
LOG_LEVEL=info

# ── Whisper STT ──────────────────────────────────────────
WHISPER_MODEL_SIZE=medium
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=en

# ── Ollama LLM ───────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=60

# ── TTS Engine ───────────────────────────────────────────
TTS_ENGINE=xtts
XTTS_MODEL_PATH=./models/xtts
FISH_MODEL_PATH=./models/fish
TTS_DEVICE=auto

# ── Audio ────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
OUTPUT_DIR=./output
MAX_AUDIO_DURATION=300

# ── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
