# =============================================================
#  Nativeify — Environment Variables
#  Copy this file to .env and adjust values for your setup.
#  Never commit .env to version control.
# =============================================================

# ── Backend Server ───────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Set to false in production
BACKEND_RELOAD=true
# debug | info | warning | error
LOG_LEVEL=info

# ── Whisper STT ──────────────────────────────────────────
# Model size: tiny | base | small | medium | large-v2 | large-v3
# Larger = more accurate, slower, more VRAM
# Recommended: medium (good speed/accuracy balance)
WHISPER_MODEL_SIZE=medium

# Device: auto | cpu | cuda
# auto = use CUDA if available, else CPU
WHISPER_DEVICE=auto

# Compute type: float16 | int8 | float32
# float16 = fastest on GPU | int8 = fastest on CPU | float32 = safest
WHISPER_COMPUTE_TYPE=float16

# Language hint (improves accuracy). Use 'en' for English.
WHISPER_LANGUAGE=en

# ── Ollama LLM (Grammar Correction) ─────────────────────
# Ollama server URL
OLLAMA_HOST=http://localhost:11434

# Model to use for grammar correction
# Recommended: llama3.2:3b (fast, ~2GB RAM)
# Alternatives: mistral:7b | phi3:mini | llama3.1:8b
OLLAMA_MODEL=llama3.2:3b

# Request timeout in seconds
OLLAMA_TIMEOUT=60

# ── TTS Engine ───────────────────────────────────────────
# Engine: xtts | fish
# xtts = XTTS-v2 (best quality, voice cloning, ~2GB VRAM)
# fish = Fish Speech (lighter, CPU-friendly)
TTS_ENGINE=xtts

# Path to XTTS-v2 model directory (auto-downloaded on first run)
XTTS_MODEL_PATH=./models/xtts

# Path to Fish Speech model directory
FISH_MODEL_PATH=./models/fish

# TTS device: auto | cpu | cuda
TTS_DEVICE=auto

# ── Audio Processing ─────────────────────────────────────
# Path to ffmpeg binary. Use 'ffmpeg' if it's in your PATH.
FFMPEG_PATH=ffmpeg

# Directory where generated audio files are saved
OUTPUT_DIR=./output

# Maximum allowed audio input duration in seconds (5 min = 300)
MAX_AUDIO_DURATION=300

# ── CORS / Security ──────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Frontend ─────────────────────────────────────────────
# Backend API base URL (used by React via Vite env)
VITE_API_URL=http://localhost:8000/api/v1
